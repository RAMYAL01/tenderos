# ─────────────────────────────────────────────────────────────────
# TenderOS — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL) ─────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# On Neon/Supabase: DATABASE_URL = pooled endpoint, DIRECT_URL = direct endpoint
DATABASE_URL="postgresql://postgres:password@localhost:5432/tenderos?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/tenderos?schema=public"

# ── Clerk Authentication ──────────────────────────────────────────
# Get from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Webhook secret — get from Clerk Dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# ── AWS S3 ────────────────────────────────────────────────────────
# Create an IAM user with S3 permissions and generate access keys
AWS_ACCESS_KEY_ID="AKIAxxxxxxxxxxxxxxxx"
AWS_SECRET_ACCESS_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
AWS_REGION="me-central-1"
AWS_S3_BUCKET_NAME="tenderos-documents"
# Optional: CloudFront CDN URL for document delivery
AWS_CLOUDFRONT_URL=""

# ── AI Providers ──────────────────────────────────────────────────
# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Azure Document Intelligence (OCR for scanned PDFs) ────────────────
# Optional. When set, scanned/image PDFs are OCR'd instead of rejected.
# Create a "Document Intelligence" (Form Recognizer) resource in the Azure
# portal → Keys and Endpoint. Leave blank to keep OCR disabled.
AZURE_DOCINTEL_ENDPOINT="https://<your-resource>.cognitiveservices.azure.com"
AZURE_DOCINTEL_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── App Config ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="TenderOS"

# ── Internal ──────────────────────────────────────────────────────
# Secret key for internal API-to-API calls (e.g., trigger document processing)
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY="change-me-to-a-random-secret"

# ── Stripe Billing ───────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com → Developers → API keys.
# Use sk_test_… while testing; switch to sk_live_… for production.
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Webhook signing secret — Stripe Dashboard → Developers → Webhooks →
# add endpoint https://www.thetenderos.com/api/webhooks/stripe → reveal secret.
# For local testing, `stripe listen` prints a whsec_… to use here.
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Recurring Price IDs (one per plan × billing cycle). Create three Products
# (Starter / Professional / Business), each with a monthly + an annual Price,
# in Stripe Dashboard → Product catalog. Paste the price_… IDs here.
STRIPE_PRICE_STARTER_MONTHLY="price_xxxxxxxxxxxx"
STRIPE_PRICE_STARTER_ANNUAL="price_xxxxxxxxxxxx"
STRIPE_PRICE_PROFESSIONAL_MONTHLY="price_xxxxxxxxxxxx"
STRIPE_PRICE_PROFESSIONAL_ANNUAL="price_xxxxxxxxxxxx"
STRIPE_PRICE_BUSINESS_MONTHLY="price_xxxxxxxxxxxx"
STRIPE_PRICE_BUSINESS_ANNUAL="price_xxxxxxxxxxxx"
