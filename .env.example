# ─────────────────────────────────────────────────────────────────
# TenderOS — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL) ─────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# On Neon/Supabase: DATABASE_URL = pooled endpoint, DIRECT_URL = direct endpoint
DATABASE_URL="postgresql://postgres:password@localhost:5432/tenderos?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/tenderos?schema=public"

# ── Clerk Authentication ──────────────────────────────────────────
# Get from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Webhook secret — get from Clerk Dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# ── AWS S3 ────────────────────────────────────────────────────────
# Create an IAM user with S3 permissions and generate access keys
AWS_ACCESS_KEY_ID="AKIAxxxxxxxxxxxxxxxx"
AWS_SECRET_ACCESS_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
AWS_REGION="me-central-1"
AWS_S3_BUCKET_NAME="tenderos-documents"
# Optional: CloudFront CDN URL for document delivery
AWS_CLOUDFRONT_URL=""

# ── AI Providers ──────────────────────────────────────────────────
# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Chat LLM provider (cloud vs on-prem) ──────────────────────────────
# cloud (default) -> Anthropic Claude (uses ANTHROPIC_API_KEY).
# local           -> any OpenAI-compatible endpoint (vLLM/Ollama/TGI) inside
#                    your network. Enterprise/air-gapped edition sets this.
LLM_PROVIDER="cloud"
# Used only when LLM_PROVIDER=local:
# LLM_BASE_URL="http://vllm:8000/v1"
# LLM_MODEL="tenderos"
# LLM_API_KEY="not-needed"

# ── Embeddings (Corporate Memory / RAG) ───────────────────────────────
# Which provider embeds knowledge chunks + search queries.
#   openai (default) — text-embedding-3-large @ 1536 dims (uses OPENAI_API_KEY).
#   ollama           — fully local, zero-cloud. The model MUST emit 1536-dim
#                      vectors to match the pgvector column (or re-index).
EMBEDDING_PROVIDER="openai"
# Only used when EMBEDDING_PROVIDER=ollama:
# OLLAMA_HOST="http://127.0.0.1:11434"
# OLLAMA_EMBED_MODEL="nomic-embed-text"
# OLLAMA_EMBED_DIMS="1536"

# ── Scanned-PDF OCR ───────────────────────────────────────────────────
# Scanned/image PDFs are OCR'd into text+tables instead of being rejected.
# Provider precedence: Azure -> local-vision -> Claude.
#   1. Azure Document Intelligence — if the two vars below are set (best fidelity).
#   2. Local vision VLM (air-gapped) — OCR_PROVIDER=local-vision: rasterize with
#      poppler (`pdftoppm`, must be in the image) then transcribe each page on the
#      on-prem Qwen2.5-VL via vLLM. NO external call.
#   3. Claude vision — else falls back to ANTHROPIC_API_KEY (cloud default).
AZURE_DOCINTEL_ENDPOINT=""
AZURE_DOCINTEL_KEY=""
# Air-gapped local vision OCR:
# OCR_PROVIDER="local-vision"
# OCR_VISION_BASE_URL="http://vllm-vl:8000/v1"   # defaults to LLM_BASE_URL
# OCR_VISION_MODEL="tenderos-vl"
# OCR_VISION_DPI="150"

# ── App Config ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="TenderOS"

# ── Internal ──────────────────────────────────────────────────────
# Secret key for internal API-to-API calls (e.g., trigger document processing)
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY="change-me-to-a-random-secret"

# ── Stripe Billing ───────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com → Developers → API keys.
# Use sk_test_… while testing; switch to sk_live_… for production.
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Webhook signing secret — Stripe Dashboard → Developers → Webhooks →
# add endpoint https://www.thetenderos.com/api/webhooks/stripe → reveal secret.
# For local testing, `stripe listen` prints a whsec_… to use here.
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Recurring Price IDs (one per plan × billing cycle). Create three Products
# (Starter / Professional / Business), each with a monthly + an annual Price,
# in Stripe Dashboard → Product catalog. Paste the price_… IDs here.
STRIPE_PRICE_STARTER_MONTHLY="price_xxxxxxxxxxxx"
STRIPE_PRICE_STARTER_ANNUAL="price_xxxxxxxxxxxx"
STRIPE_PRICE_PROFESSIONAL_MONTHLY="price_xxxxxxxxxxxx"
STRIPE_PRICE_PROFESSIONAL_ANNUAL="price_xxxxxxxxxxxx"
STRIPE_PRICE_BUSINESS_MONTHLY="price_xxxxxxxxxxxx"
STRIPE_PRICE_BUSINESS_ANNUAL="price_xxxxxxxxxxxx"
