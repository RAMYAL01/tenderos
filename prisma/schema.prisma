// ─────────────────────────────────────────────────────────────────────────────
// TenderOS — Prisma Schema
// PostgreSQL · Prisma ORM
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled connection (Neon / PgBouncer)
  directUrl = env("DIRECT_URL") // direct connection for migrations
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum PlanTier {
  STARTER
  PROFESSIONAL
  BUSINESS
  ENTERPRISE
}

enum MemberRole {
  OWNER
  ADMIN
  MANAGER
  SENIOR_WRITER
  WRITER
  REVIEWER
  VIEWER
}

/// What kind of company the workspace belongs to (onboarding Step 1).
enum OrganizationType {
  GENERAL_CONTRACTOR
  EPC_CONTRACTOR
  CONSTRUCTION_COMPANY
  ENGINEERING_CONSULTANT
  FACILITIES_MANAGEMENT
  GOVERNMENT_AGENCY
  SUPPLIER_VENDOR
  OTHER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum TenderStatus {
  DRAFT
  ACTIVE
  SUBMITTED
  WON
  LOST
  NO_DECISION
  CANCELLED
}

enum DocumentStatus {
  PENDING
  QUEUED
  SCANNING
  OCR_PROCESSING
  PARSING
  INDEXING
  READY
  NEEDS_REVIEW // OCR/parse succeeded but low confidence — held for human review
  FAILED
  QUARANTINED
}

enum DocumentLanguage {
  ENGLISH
  ARABIC
  BILINGUAL
  UNKNOWN
}

enum RequirementType {
  MANDATORY
  OPTIONAL
  INFORMATIONAL
  CONDITIONAL
}

enum RequirementPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum ComplianceStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  NOT_APPLICABLE
  FLAGGED
}

enum ProposalStatus {
  DRAFT
  IN_REVIEW
  CHANGES_REQUESTED
  APPROVED
  EXPORTED
  ARCHIVED
}

enum SectionType {
  EXECUTIVE_SUMMARY
  COMPANY_OVERVIEW
  TECHNICAL_APPROACH
  METHODOLOGY
  WORK_PLAN
  TEAM_QUALIFICATIONS
  PAST_PERFORMANCE
  EQUIPMENT_RESOURCES
  HEALTH_SAFETY
  LOCAL_CONTENT
  FINANCIAL_PROPOSAL
  CLARIFICATIONS
  APPENDIX
  COVER_LETTER
  CUSTOM
}

enum ExportFormat {
  PDF
  DOCX
  BILINGUAL_PDF
  BILINGUAL_DOCX
}

enum JobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  RETRYING
}

enum AIJobType {
  EXTRACT_REQUIREMENTS
  GENERATE_COMPLIANCE_MATRIX
  DRAFT_SECTION
  EXECUTIVE_SUMMARY
  CLARIFICATION_QUESTIONS
  RECOMMEND_CONTENT
  EMBED_CONTENT
  TRANSLATE_CONTENT
  BID_QUALIFICATION
}

enum ContentLanguage {
  EN
  AR
  AR_SA
  AR_AE
  AR_EG
  BILINGUAL
}

enum ContentSource {
  HUMAN
  AI_GENERATED
  AI_REVIEWED
  IMPORTED
}

enum LossReason {
  PRICE
  TECHNICAL_SCORE
  LOCAL_CONTENT
  LATE_SUBMISSION
  INCOMPLETE_SUBMISSION
  DISQUALIFIED
  NO_BID
  OTHER
}

enum CostCategory {
  LABOR
  EQUIPMENT
  MATERIAL
  SUBCONTRACTOR
  TRANSPORT
  OTHER_DIRECT
}

enum FinancialStatus {
  DRAFT
  PRICED
  APPROVED
  EXPORTED
}

// ── Tender Discovery Engine ────────────────────────────────────────────────────
enum OpportunitySourceKind {
  GOVERNMENT_PORTAL
  AGGREGATOR
  RSS
  API
  MANUAL
}

enum OpportunityStatus {
  OPEN
  CLOSING_SOON
  CLOSED
  CANCELLED
}

/// Per-tenant lifecycle of a discovered opportunity. NEW = system-suggested
/// (does NOT count against the tracked-opportunity quota). SAVED/CONVERTED =
/// explicit user commitment (counts). DISMISSED = pruned from the feed.
enum MatchTrackingStatus {
  NEW
  VIEWED
  SAVED
  DISMISSED
  CONVERTED
}

enum AlertFrequency {
  INSTANT // scaffolded; only DAILY is honored under Vercel Hobby daily-cron
  DAILY
  WEEKLY
}

enum AlertChannel {
  IN_APP
  EMAIL // scaffolded; no email infra yet
  WEBHOOK
}

enum AlertStatus {
  PENDING
  SENT
  FAILED
}

// ── Bid/No-Bid Qualification Engine ───────────────────────────────────────────
enum BidRecommendation {
  BID
  NO_BID
  REVIEW // not enough signal either way — human judgment required
}

// ── Proposal review gates ─────────────────────────────────────────────────────
enum ProposalReviewAction {
  SUBMITTED // writer → IN_REVIEW
  APPROVED // manager → APPROVED
  CHANGES_REQUESTED // manager → CHANGES_REQUESTED (note required)
  REOPENED // manager reopens an approved proposal → DRAFT
}

// Marketplace partner-connection lifecycle (Sprint 8b). A connection is a
// directed request requester → addressee; ACCEPTED unlocks private contact info.
enum ConnectionStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// ── Email platform (Resend) ───────────────────────────────────────────────────
/// Lifecycle of a single outbound email. QUEUED→SENDING→SENT are set by our
/// sender; DELIVERED/BOUNCED/COMPLAINED arrive later via Resend webhooks.
enum EmailStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  FAILED
  BOUNCED
  COMPLAINED
  CANCELLED
}

/// Email category — the unit a member can mute in NotificationPreference.
/// TRANSACTIONAL is never mutable (invites, welcome, password reset).
enum EmailCategory {
  TRANSACTIONAL
  DIGEST
  PROPOSAL
  APPROVAL
  BILLING
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 1: Organization
// Multi-tenant root. Every other table has orgId → this.
// clerkOrgId links to Clerk's organization system.
// ─────────────────────────────────────────────────────────────────────────────
model Organization {
  id                      String            @id @default(cuid())
  clerkOrgId              String            @unique // Clerk org ID e.g. "org_xxxx"
  name                    String
  nameAr                  String? // Arabic organization name
  slug                    String            @unique
  planTier                PlanTier          @default(STARTER)
  maxSeats                Int               @default(3)
  maxProposalsMonth       Int               @default(5)
  aiCreditsMonth          Int               @default(50)
  storageBytesLimit       BigInt            @default(2147483648) // 2 GB
  storageBytesUsed        BigInt            @default(0)
  defaultLanguage         ContentLanguage   @default(EN)
  industry                String? // construction | defense | facilities | oil_gas
  organizationType        OrganizationType? // onboarding Step 1
  employeeCount           String? // banded: "1-10" | "11-50" | "51-200" | "201-500" | "500+"
  countryCode             String?           @db.Char(2) // ISO 3166-1: AE, SA, EG, QA
  settings                Json              @default("{}")
  logoUrl                 String?
  website                 String?
  isActive                Boolean           @default(true)
  trialEndsAt             DateTime?
  // Discovery plan limits (standing-inventory caps; -1 = unlimited per quota.ts).
  maxSavedSearches        Int               @default(1)
  maxTrackedOpportunities Int               @default(10)
  // Org-first onboarding: null until the workspace wizard is completed.
  onboardingCompletedAt   DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  deletedAt               DateTime?

  // Relations
  members                 Member[]
  tenders                 Tender[]
  contentLibraryItems     ContentLibraryItem[]
  knowledgeChunks         KnowledgeChunk[]
  boqWorkflows            BoqWorkflow[]
  aiFeedback              AIFeedback[]
  invitations             Invitation[]
  aiJobs                  AIJob[]
  subscription            Subscription?
  auditLogs               AuditLog[]
  financialProposals      FinancialProposal[]
  rateCatalogueItems      RateCatalogueItem[]
  vendors                 Vendor[]
  apiKeys                 ApiKey[]
  webhookEndpoints        WebhookEndpoint[]
  webhookDeliveries       WebhookDelivery[]
  savedSearches           SavedSearch[]
  opportunityMatches      OpportunityMatch[]
  opportunityAlerts       OpportunityAlert[]
  bidDecisions            BidDecision[]
  proposalReviews         ProposalReviewEvent[]
  marketplaceProfile      MarketplaceProfile?
  sentConnections         PartnerConnection[]      @relation("ConnectionRequester")
  receivedConnections     PartnerConnection[]      @relation("ConnectionAddressee")
  emailLogs               EmailLog[]
  notificationPreferences NotificationPreference[]
  // NOTE: deliberately NO relation to Opportunity / OpportunitySource — those are
  // a GLOBAL shared catalog with no orgId. The tenant boundary lives on
  // OpportunityMatch (the per-tenant join). See models at the end of this file.

  @@map("organizations")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 2: Member
// A Clerk user within an organization workspace.
// Clerk handles the actual auth; we store workspace-level profile + role.
// ─────────────────────────────────────────────────────────────────────────────
model Member {
  id                String          @id @default(cuid())
  clerkUserId       String // Clerk user ID e.g. "user_xxxx"
  orgId             String
  email             String
  name              String
  nameAr            String?
  role              MemberRole      @default(WRITER)
  avatarUrl         String?
  preferredLanguage ContentLanguage @default(EN)
  mfaEnabled        Boolean         @default(false)
  lastLoginAt       DateTime?
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  // Relations
  organization           Organization            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdTenders         Tender[]                @relation("TenderCreatedBy")
  managedTenders         Tender[]                @relation("TenderManager")
  uploadedDocuments      Document[]
  assignedCompliance     ComplianceMatrixRow[]   @relation("ComplianceAssignee")
  createdProposals       Proposal[]
  assignedSections       ProposalSection[]       @relation("SectionAssignee")
  editedSections         ProposalSection[]       @relation("SectionEditor")
  createdVersions        ProposalVersion[]
  comments               ProposalComment[]
  libraryItems           ContentLibraryItem[]
  exportJobs             ExportJob[]
  auditLogs              AuditLog[]
  emailLogs              EmailLog[]
  notificationPreference NotificationPreference?

  @@unique([orgId, clerkUserId])
  @@unique([orgId, email])
  @@map("members")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 3: Tender
// The top-level container for each bid project.
// Everything (documents, requirements, proposals) belongs to a tender.
// ─────────────────────────────────────────────────────────────────────────────
model Tender {
  id                  String          @id @default(cuid())
  orgId               String
  titleEn             String
  titleAr             String?
  referenceNo         String? // Client's RFP reference number
  clientName          String?
  clientNameAr        String?
  clientCountry       String?         @db.Char(2)
  sector              String? // construction | defense | facilities | oil_gas
  tenderType          String? // RFP | RFQ | ITB | EOI | ITT
  submissionDeadline  DateTime?
  estimatedValue      Decimal?        @db.Decimal(18, 2)
  currency            String?         @default("USD") @db.Char(3)
  status              TenderStatus    @default(DRAFT)
  primaryLanguage     ContentLanguage @default(EN)
  tags                String[]        @default([])
  notes               String?
  lossReason          LossReason?
  outcomeNotes        String? // Post-bid debrief notes
  // Structured outcome debrief (Win/Loss Intelligence — feeds the discovery
  // matcher, the bid qualifier, and the analytics win/loss panel).
  awardedValue        Decimal?        @db.Decimal(18, 2) // actual contract value (WON)
  winningCompetitor   String? // who took it (LOST) — competitor intelligence
  outcomeRecordedAt   DateTime?
  outcomeRecordedById String?
  // Provenance: the discovered Opportunity this tender was converted from (if any).
  // Nullable, no cascade — the global catalog must never cascade-delete tenant data.
  sourceOpportunityId String?
  createdById         String
  assignedManagerId   String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?

  // Relations
  organization       Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy          Member                @relation("TenderCreatedBy", fields: [createdById], references: [id])
  assignedManager    Member?               @relation("TenderManager", fields: [assignedManagerId], references: [id])
  documents          Document[]
  requirements       Requirement[]
  proposals          Proposal[]
  complianceRows     ComplianceMatrixRow[]
  financialProposals FinancialProposal[]
  fromOpportunity    OpportunityMatch[]    @relation("TenderFromOpportunity")
  bidDecision        BidDecision?

  @@index([orgId, status])
  @@index([orgId, deletedAt])
  @@index([createdById])
  @@index([assignedManagerId])
  @@map("tenders")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 4: Document
// An uploaded RFP/RFQ file. Processing happens async via job queue.
// storageKey → S3 object key.
// ─────────────────────────────────────────────────────────────────────────────
model Document {
  id                 String            @id @default(cuid())
  tenderId           String
  orgId              String
  filename           String
  originalFilename   String
  storageKey         String            @unique // S3 key
  storageBucket      String
  mimeType           String
  fileSizeBytes      BigInt
  pageCount          Int?
  languageDetected   DocumentLanguage?
  languageConfidence Float? // 0.0–1.0
  extractionMethod   String? // pdf-parse | mammoth | plaintext | azure-ocr | claude-ocr
  processingStatus   DocumentStatus    @default(PENDING)
  errorMessage       String?
  retryCount         Int               @default(0)
  ocrCompletedAt     DateTime?
  indexedAt          DateTime?
  checksumSha256     String? // For dedup detection
  isPrimary          Boolean           @default(false) // Main RFP document
  uploadedById       String
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?

  // Relations
  tender       Tender               @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  uploadedBy   Member               @relation(fields: [uploadedById], references: [id])
  requirements Requirement[]
  reviewFlags  DocumentReviewFlag[]

  @@index([tenderId])
  @@index([orgId, processingStatus])
  @@index([uploadedById])
  @@map("documents")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL: DocumentReviewFlag
// Fault tolerance for the ingestion pipeline. When OCR/stitching confidence is
// too low to trust (unreadable table, inconsistent column counts, low word
// confidence), the pipeline records a flag here and sets the document to
// NEEDS_REVIEW instead of silently emitting garbage. A human resolves it.
// ─────────────────────────────────────────────────────────────────────────────
enum ReviewFlagType {
  LOW_OCR_CONFIDENCE
  UNREADABLE_TABLE
  TABLE_COLUMN_MISMATCH
  EMPTY_PAGE
  STITCH_AMBIGUITY
  LANGUAGE_DETECTION_LOW
  LLM_STRUCTURING_FAILED
}

enum ReviewFlagSeverity {
  WARNING // proceed, but surface to the user
  BLOCKER // hold the document; do not auto-promote downstream
}

model DocumentReviewFlag {
  id         String             @id @default(cuid())
  documentId String
  orgId      String
  type       ReviewFlagType
  severity   ReviewFlagSeverity @default(WARNING)
  message    String
  pageNumber Int? // 1-based page the issue was found on, if applicable
  tableIndex Int? // index of the offending table on that page, if applicable
  confidence Float? // 0.0–1.0 aggregate confidence that triggered the flag
  context    Json? // arbitrary debug payload (bounding regions, raw snippet)
  resolved   Boolean            @default(false)
  resolvedBy String?
  resolvedAt DateTime?
  createdAt  DateTime           @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([orgId, resolved])
  @@map("document_review_flags")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 5: Requirement
// An individual requirement extracted from a tender document.
// Both AI-extracted and manually added requirements live here.
// ─────────────────────────────────────────────────────────────────────────────
model Requirement {
  id              String              @id @default(cuid())
  tenderId        String
  documentId      String?
  orgId           String
  textEn          String? // English requirement text
  textAr          String? // Arabic requirement text
  sectionRef      String? // Source section e.g. "Section 3.2.1"
  pageRef         Int? // Source page number
  requirementType RequirementType     @default(MANDATORY)
  priority        RequirementPriority @default(HIGH)
  confidenceScore Float? // AI confidence 0.0–1.0
  isAiExtracted   Boolean             @default(true)
  tags            String[]            @default([])
  createdById     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?

  // Relations
  tender        Tender               @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  document      Document?            @relation(fields: [documentId], references: [id], onDelete: SetNull)
  complianceRow ComplianceMatrixRow?

  @@index([tenderId, deletedAt])
  @@index([orgId])
  @@index([documentId])
  @@map("requirements")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 6: ComplianceMatrixRow
// One row per requirement per tender.
// Tracks how (and whether) each requirement is addressed.
// ─────────────────────────────────────────────────────────────────────────────
model ComplianceMatrixRow {
  id               String           @id @default(cuid())
  tenderId         String
  requirementId    String           @unique // One matrix row per requirement
  orgId            String
  responseEn       String? // How we address this requirement (English)
  responseAr       String? // How we address this requirement (Arabic)
  sectionReference String? // Which proposal section addresses this
  status           ComplianceStatus @default(NOT_STARTED)
  assignedToId     String?
  dueDate          DateTime?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  tender      Tender      @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  requirement Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  assignedTo  Member?     @relation("ComplianceAssignee", fields: [assignedToId], references: [id])

  @@index([tenderId, status])
  @@index([orgId])
  @@index([assignedToId])
  @@map("compliance_matrix_rows")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 7: Proposal
// A draft technical proposal for a tender.
// Multiple proposals can exist per tender (e.g., EN + AR versions).
// ─────────────────────────────────────────────────────────────────────────────
model Proposal {
  id              String          @id @default(cuid())
  tenderId        String
  orgId           String
  title           String
  language        ContentLanguage @default(EN)
  status          ProposalStatus  @default(DRAFT)
  currentVersion  Int             @default(1)
  complianceScore Float? // Cached %, recalculated on compliance update
  submittedAt     DateTime?
  createdById     String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  // Relations
  tender       Tender                @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  createdBy    Member                @relation(fields: [createdById], references: [id])
  sections     ProposalSection[]
  versions     ProposalVersion[]
  comments     ProposalComment[]
  exportJobs   ExportJob[]
  reviewEvents ProposalReviewEvent[]

  @@index([tenderId, deletedAt])
  @@index([orgId, status])
  @@index([createdById])
  @@map("proposals")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 8: ProposalSection
// A single section within a proposal (e.g., Technical Approach, Methodology).
// Supports both AI-generated and human-authored content, bilingual.
// ─────────────────────────────────────────────────────────────────────────────
model ProposalSection {
  id             String        @id @default(cuid())
  proposalId     String
  orgId          String
  sectionType    SectionType   @default(CUSTOM)
  titleEn        String?
  titleAr        String?
  contentEn      String?       @db.Text // Rich text / Markdown
  contentAr      String?       @db.Text
  orderIndex     Int           @default(0)
  isAiGenerated  Boolean       @default(false)
  aiModelUsed    String? // e.g. "claude-3-5-sonnet-20241022"
  contentSource  ContentSource @default(HUMAN)
  assignedToId   String?
  lastEditedById String?
  isLocked       Boolean       @default(false) // Prevent concurrent edits
  lockedById     String? // Member ID (no relation — simple lock ref)
  lockedAt       DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  // Relations
  proposal     Proposal          @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  assignedTo   Member?           @relation("SectionAssignee", fields: [assignedToId], references: [id])
  lastEditedBy Member?           @relation("SectionEditor", fields: [lastEditedById], references: [id])
  comments     ProposalComment[]

  @@index([proposalId, orderIndex])
  @@index([orgId])
  @@index([assignedToId])
  @@index([lastEditedById])
  @@map("proposal_sections")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 9: ProposalVersion
// Immutable snapshots of a proposal at a point in time.
// snapshot JSON contains the full sections content for that version.
// ─────────────────────────────────────────────────────────────────────────────
model ProposalVersion {
  id              String   @id @default(cuid())
  proposalId      String
  orgId           String
  versionNumber   Int
  label           String? // e.g. "v3 - Final Review"
  snapshot        Json // Full ProposalSection[] snapshot
  changeSummary   String?
  complianceScore Float?
  createdById     String
  createdAt       DateTime @default(now())

  // Relations
  proposal  Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  createdBy Member   @relation(fields: [createdById], references: [id])

  @@unique([proposalId, versionNumber])
  @@index([orgId])
  @@index([createdById])
  @@map("proposal_versions")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 10: ContentLibraryItem
// Reusable content blocks — past performance, CVs, methodology templates.
// Supports semantic search via embedding (stored externally or future pgvector).
// ─────────────────────────────────────────────────────────────────────────────
model ContentLibraryItem {
  id            String                       @id @default(cuid())
  orgId         String
  titleEn       String
  titleAr       String?
  contentEn     String?                      @db.Text
  contentAr     String?                      @db.Text
  sectionType   SectionType?
  tags          String[]                     @default([])
  language      ContentLanguage              @default(EN)
  isTemplate    Boolean                      @default(false) // Workspace-wide template
  usageCount    Int                          @default(0)
  contentSource ContentSource                @default(HUMAN)
  // Embedding stored as JSON array (legacy in-process cosine path)
  embeddingEn   Json? // Float[] from OpenAI text-embedding-3-large
  embeddingAr   Json?
  // pgvector column for tenant-bound RAG (queried only via $queryRaw).
  // Backed by Neon `vector` extension; see src/lib/security/rag-search.ts.
  embedding     Unsupported("vector(1536)")?
  createdById   String
  createdAt     DateTime                     @default(now())
  updatedAt     DateTime                     @updatedAt
  deletedAt     DateTime?

  // Relations
  organization Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy    Member           @relation(fields: [createdById], references: [id])
  chunks       KnowledgeChunk[]

  @@index([orgId, deletedAt])
  @@index([createdById])
  @@map("content_library_items")
}

/// Chunk-level corporate memory for tenant-isolated RAG.
/// Every row is bound to a single tenant (`orgId`) — the retrieval query
/// pre-filters on `orgId` BEFORE the vector distance calc, so a chunk from
/// another tenant can never be ranked or returned. The `embedding` column is a
/// real pgvector(1536); it is written and queried ONLY via raw SQL
/// ($executeRaw / $queryRaw), never the typed client.
model KnowledgeChunk {
  id         String                       @id @default(cuid())
  orgId      String // TENANT BINDING — present on every chunk for pre-rank isolation
  sourceId   String // -> ContentLibraryItem (the parent document)
  chunkIndex Int // 0-based position within the source document
  content    String                       @db.Text
  tokenCount Int                          @default(0)
  model      String? // embedding model id, for provenance / re-embed on model swap
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime                     @default(now())

  organization Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  source       ContentLibraryItem @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, chunkIndex])
  @@index([orgId])
  @@map("knowledge_chunks")
}

/// Persisted state for the multi-agent BOQ/RFP workflow (Step 2).
/// Each step transition is committed here, so a serverless function can run one
/// step per invocation and the run is resumable after a timeout/crash. Every
/// query is org-scoped — a workflow can only be advanced by its own tenant.
enum BoqWorkflowStatus {
  DRAFT
  EXTRACTING
  EXTRACTED
  COMPLIANCE_CHECKING
  COMPLIANCE_CHECKED
  PRICING
  PRICED
  FAILED
}

model BoqWorkflow {
  id          String            @id @default(cuid())
  orgId       String // TENANT BINDING
  tenderId    String?
  createdById String?
  status      BoqWorkflowStatus @default(DRAFT)

  // Routed data between steps — each is a validated payload, not free text.
  sourceText   String? @db.Text // raw BOQ/RFP text (input)
  requirements Json? // string[] technical requirements (input to compliance)
  config       Json? // PricingConfig (overhead %, profit %, currency)
  extraction   Json? // BoqExtraction (validated extractor output)
  compliance   Json? // compliance matrix (compliance agent output)
  pricing      Json? // BoqPricingResult (deterministic financial output)

  error       String?
  failedStep  String?
  attempts    Int       @default(0)
  startedAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@map("boq_workflows")
}

/// Phase-3 feedback flywheel. Every time a domain expert reviews an AI output
/// (extraction, compliance, risk, proposal, scope, BOQ classification) the
/// action + the before/after is captured here. The training-export pipeline
/// (lib/training/export.ts) turns these into de-identified SFT/DPO datasets:
///   ACCEPT/EDIT -> SFT gold (input -> human-approved output)
///   EDIT        -> DPO pair (chosen = human, rejected = ai)
///   REJECT      -> hard negative
enum AIFeedbackAction {
  ACCEPT
  EDIT
  REJECT
}

model AIFeedback {
  id           String           @id @default(cuid())
  orgId        String // TENANT BINDING
  memberId     String?
  task         String // requirement_extraction | compliance_analysis | risk_identification | proposal_generation | scope_interpretation | boq_classification
  action       AIFeedbackAction
  reviewerRole String? // estimator | procurement_manager | proposal_manager
  modelVersion String? // which model produced aiOutput (provenance / regression tracking)
  lang         String? // ar | en | mixed
  inputRef     String? // id of the reviewed resource (requirementId / boqWorkflowId / proposalSectionId)
  inputText    String?          @db.Text // the input shown to the model (for SFT reconstruction)
  aiOutput     Json // what the model produced
  humanOutput  Json? // the corrected/approved version (for EDIT/ACCEPT)
  reason       String? // free-text rejection/edit reason -> hard-negative signal
  exportedAt   DateTime? // set when this row has been materialized into a dataset version
  createdAt    DateTime         @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, task])
  @@index([exportedAt])
  @@map("ai_feedback")
}

/// Workspace team invitation (org-first, link-based — works cloud + air-gapped,
/// no external email dependency). An OWNER/ADMIN invites a work email at a role;
/// the invitee accepts via /invite/<token> and joins THIS workspace (never a new
/// org). Tenant-scoped: an invitation only ever grants access to its own org.
model Invitation {
  id           String           @id @default(cuid())
  orgId        String // the workspace being joined
  email        String // invited work email (lowercased)
  role         MemberRole       @default(WRITER)
  token        String           @unique
  status       InvitationStatus @default(PENDING)
  invitedById  String? // member who sent it
  acceptedById String? // member created on accept
  expiresAt    DateTime
  acceptedAt   DateTime?
  createdAt    DateTime         @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, email]) // one active invite per email per workspace
  @@index([orgId, status])
  @@map("invitations")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 11: ProposalComment
// Inline comments on proposals and sections. Supports threaded replies.
// ─────────────────────────────────────────────────────────────────────────────
model ProposalComment {
  id           String    @id @default(cuid())
  proposalId   String
  sectionId    String?
  orgId        String
  parentId     String? // For threaded replies
  text         String
  mentions     String[]  @default([]) // Member IDs mentioned with @
  isResolved   Boolean   @default(false)
  resolvedById String? // Member ID (no relation — simple ref)
  resolvedAt   DateTime?
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  // Relations
  proposal  Proposal          @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  section   ProposalSection?  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  parent    ProposalComment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies   ProposalComment[] @relation("CommentThread")
  createdBy Member            @relation(fields: [createdById], references: [id])

  @@index([proposalId, deletedAt])
  @@index([sectionId])
  @@index([orgId])
  @@index([parentId])
  @@index([createdById])
  @@map("proposal_comments")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 12: ExportJob
// Tracks async export operations (PDF/DOCX generation).
// outputStorageKey → S3 key of generated file.
// ─────────────────────────────────────────────────────────────────────────────
model ExportJob {
  id                String          @id @default(cuid())
  proposalId        String
  orgId             String
  format            ExportFormat
  language          ContentLanguage
  status            JobStatus       @default(QUEUED)
  outputStorageKey  String? // S3 key
  outputFilename    String?
  outputSizeBytes   BigInt?
  downloadExpiresAt DateTime? // Pre-signed URL expiry
  errorMessage      String?
  processingMs      Int?
  createdById       String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  proposal  Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  createdBy Member   @relation(fields: [createdById], references: [id])

  @@index([proposalId])
  @@index([orgId, status])
  @@index([createdById])
  @@map("export_jobs")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 13: AIJob
// Tracks all AI operations for cost accounting and quota management.
// Covers extraction, drafting, translation, embedding, etc.
// ─────────────────────────────────────────────────────────────────────────────
model AIJob {
  id               String    @id @default(cuid())
  orgId            String
  memberId         String?
  jobType          AIJobType
  resourceType     String? // tender | document | proposal | section
  resourceId       String? // ID of the resource being processed
  modelName        String? // e.g. "claude-3-5-sonnet-20241022"
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  costUsd          Decimal?  @db.Decimal(10, 6)
  latencyMs        Int?
  status           JobStatus @default(QUEUED)
  progress         Int       @default(0) // 0–100
  resultRef        String? // S3 key or inline JSON for small results
  errorMessage     String?
  retryCount       Int       @default(0)
  maxRetries       Int       @default(3)
  inputMetadata    Json      @default("{}")
  outputMetadata   Json      @default("{}")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@map("ai_jobs")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 14: Subscription
// One subscription per organization. Tracks Stripe billing state.
// ─────────────────────────────────────────────────────────────────────────────
model Subscription {
  id                 String    @id @default(cuid())
  orgId              String    @unique
  planTier           PlanTier
  seats              Int       @default(3)
  billingCycle       String    @default("monthly") // monthly | annual
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean   @default(false)
  stripeCustomerId   String?
  stripeSubId        String?   @unique
  stripePriceId      String?
  proposalsUsed      Int       @default(0)
  aiCreditsUsed      Int       @default(0)
  storageBytesUsed   BigInt    @default(0)
  isTrial            Boolean   @default(false)
  trialEndsAt        DateTime?
  // status: trialing | active | past_due | cancelled | unpaid
  status             String    @default("active")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 15: AuditLog
// Immutable audit trail. Records every significant action.
// Application code INSERTS only — never updates or deletes rows here.
// ─────────────────────────────────────────────────────────────────────────────
model AuditLog {
  id           String   @id @default(cuid())
  orgId        String?
  memberId     String?
  action       String // e.g. "document.upload" | "proposal.export" | "member.role_changed"
  resourceType String? // tender | document | proposal | member
  resourceId   String?
  oldValues    Json? // Before state (for updates)
  newValues    Json? // After state
  metadata     Json     @default("{}") // IP, user agent, session
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  // Relations
  organization Organization? @relation(fields: [orgId], references: [id])
  member       Member?       @relation(fields: [memberId], references: [id])

  @@index([orgId, createdAt])
  @@index([memberId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 16: FinancialProposal
// A priced commercial proposal for a tender. ALL monetary values derive
// deterministically from user-entered CostLines + user-set assumptions.
// No AI ever sets or invents a price — see src/lib/financial/calculate.ts.
// ─────────────────────────────────────────────────────────────────────────────
model FinancialProposal {
  id              String          @id @default(cuid())
  tenderId        String
  orgId           String
  title           String          @default("Financial Proposal")
  currency        String          @default("SAR") @db.Char(3)
  // Assumptions — user-entered percentages applied during calculation
  overheadPct     Decimal         @default(0) @db.Decimal(7, 4) // % of direct cost
  contingencyPct  Decimal         @default(0) @db.Decimal(7, 4) // % of (direct + overhead)
  profitMarginPct Decimal         @default(0) @db.Decimal(7, 4) // markup %
  vatPct          Decimal         @default(0) @db.Decimal(7, 4) // tax %
  notes           String?
  status          FinancialStatus @default(DRAFT)
  createdById     String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  tender       Tender       @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lines        CostLine[]

  @@index([tenderId])
  @@map("financial_proposals")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 17: CostLine
// A single priced line item. unitRate is ALWAYS user-entered (from BOQ,
// rate cards, or vendor quotes). lineTotal = quantity * unitRate (computed).
// ─────────────────────────────────────────────────────────────────────────────
model CostLine {
  id                  String       @id @default(cuid())
  financialProposalId String
  orgId               String
  category            CostCategory @default(MATERIAL)
  itemRef             String? // BOQ reference e.g. "2.1.4"
  description         String
  descriptionAr       String?
  unit                String? // m2, hr, no, ls, m3, ton
  quantity            Decimal      @default(0) @db.Decimal(18, 4)
  unitRate            Decimal      @default(0) @db.Decimal(18, 4) // user-entered — never AI
  source              String? // provenance: "Vendor quote #A-203", "Rate card 2026"
  orderIndex          Int          @default(0)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  financialProposal FinancialProposal @relation(fields: [financialProposalId], references: [id], onDelete: Cascade)

  @@index([financialProposalId])
  @@index([orgId])
  @@map("cost_lines")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 18: RateCatalogueItem
// The company's internal unit costs (labor + materials), org-scoped. This is
// the deterministic source of truth the BOQ pricing engine queries — the AI
// NEVER reads or writes prices here. unitCost is user/admin-maintained.
// ─────────────────────────────────────────────────────────────────────────────
enum RateSourceType {
  LABOR
  MATERIAL
}

model RateCatalogueItem {
  id                String         @id @default(cuid())
  orgId             String
  itemCode          String // BOQ reference / catalogue code, e.g. "2.1.4", "L-FM-01"
  externalId        String? // source ERP id, for idempotent sync
  vendorId          String? // optional supplier of this material
  description       String?
  unitOfMeasurement String // normalized unit token: m2, m3, hr, no, ls, ton, kg
  unitCost          Decimal        @db.Decimal(18, 4) // major currency units — never AI-set
  currency          String         @default("SAR") @db.Char(3)
  source            RateSourceType
  effectiveFrom     DateTime? // optional effective-date for rate versioning
  createdById       String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  deletedAt         DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  vendor       Vendor?      @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@unique([orgId, itemCode]) // one active rate per code per org
  @@index([orgId, itemCode])
  @@index([orgId, vendorId])
  @@map("rate_catalogue_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// INTEGRATION LAYER — Vendors, API keys, Webhooks
// ─────────────────────────────────────────────────────────────────────────────

enum VendorStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

model Vendor {
  id          String       @id @default(cuid())
  orgId       String
  code        String // tenant-unique vendor code (natural key for import/upsert)
  externalId  String? // source ERP id (e.g. SAP BP number)
  name        String
  taxId       String?
  email       String?
  phone       String?
  countryCode String?      @db.Char(2)
  status      VendorStatus @default(ACTIVE)
  metadata    Json         @default("{}")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  organization Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  materials    RateCatalogueItem[]

  @@unique([orgId, code]) // idempotency key for import + ERP sync
  @@index([orgId, externalId])
  @@map("vendors")
}

model ApiKey {
  id          String    @id @default(cuid())
  orgId       String
  name        String // human label, e.g. "SAP Production"
  prefix      String // first chars shown in UI, e.g. "tk_live_a1b2"
  hashedKey   String    @unique // sha256 of the full key — the raw key is shown once
  scopes      String[]  @default([]) // e.g. ["erp:write", "vendors:write"]
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdById String?
  createdAt   DateTime  @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("api_keys")
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED // exhausted retries — dead-lettered
}

model WebhookEndpoint {
  id        String   @id @default(cuid())
  orgId     String
  url       String
  secret    String // HMAC signing secret (generated server-side)
  events    String[] @default([]) // subscribed event types, e.g. ["tender.won"]
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deliveries   WebhookDelivery[]

  @@index([orgId])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id             String                @id @default(cuid())
  orgId          String
  endpointId     String
  eventType      String
  payload        Json
  status         WebhookDeliveryStatus @default(PENDING)
  attempts       Int                   @default(0)
  maxAttempts    Int                   @default(6)
  nextAttemptAt  DateTime              @default(now())
  lastError      String?
  responseStatus Int?
  deliveredAt    DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  endpoint     WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt]) // the retry-queue scan
  @@index([orgId, eventType])
  @@map("webhook_deliveries")
}

// ═════════════════════════════════════════════════════════════════════════════
// TENDER DISCOVERY ENGINE
//
// ⚠ TENANCY EXCEPTION. Every other model in this schema is strictly org-scoped
// (orgId on every row). The Discovery catalog is the ONE deliberate exception:
// a government tender is an objective public fact, identical for every
// contractor, so OpportunitySource + Opportunity are a GLOBAL shared catalog
// with NO orgId and NO cascade to Organization.
//
// The tenant boundary moves to OpportunityMatch (the per-tenant join). Rules:
//   1. ONLY src/lib/discovery/ingest.ts may write Opportunity / OpportunitySource
//      (enforced by a CI guard test). They are read-only to tenants.
//   2. Nothing org-derived is ever written into the global rows (no per-tenant
//      keywords, no "N orgs tracking" denormalization — that would leak interest).
//   3. The cross-boundary FK is one-way: OpportunityMatch → Opportunity, with
//      onDelete Restrict/SetNull — NEVER Cascade. Org deletion cascades only the
//      per-tenant join, never the catalog.
// ═════════════════════════════════════════════════════════════════════════════

/// GLOBAL CATALOG — no orgId. A tender-publishing source (gov portal, aggregator).
/// Written ONLY by src/lib/discovery/ingest.ts.
model OpportunitySource {
  id              String                @id @default(cuid())
  name            String
  slug            String                @unique
  country         String?               @db.Char(2)
  kind            OpportunitySourceKind
  baseUrl         String?
  adapterKey      String // resolves the ingestion adapter module
  defaultLanguage ContentLanguage       @default(EN)
  isActive        Boolean               @default(true)
  lastPolledAt    DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  opportunities Opportunity[]

  @@map("opportunity_sources")
}

/// GLOBAL CATALOG — no orgId. A discovered public tender opportunity.
/// Deduped on (sourceId, externalId); contentHash detects changes on re-ingest.
/// Written ONLY by src/lib/discovery/ingest.ts. Embedding (semantic match) is
/// deferred to the P2 sprint and intentionally NOT present yet.
model Opportunity {
  id             String            @id @default(cuid())
  sourceId       String
  externalId     String // stable id within the source
  titleEn        String
  titleAr        String?
  descriptionEn  String?           @db.Text
  descriptionAr  String?           @db.Text
  buyerName      String?
  buyerNameAr    String?
  country        String?           @db.Char(2)
  sector         String? // normalized: construction | facilities | oil_gas | infrastructure | ...
  tenderType     String? // free text from source; normalized to enum on convert
  referenceNo    String?
  estimatedValue Decimal?          @db.Decimal(18, 2)
  currency       String?           @db.Char(3)
  publishedAt    DateTime?
  closingDate    DateTime?
  sourceUrl      String?
  language       ContentLanguage   @default(EN)
  contentHash    String // change-detection on re-ingest
  status         OpportunityStatus @default(OPEN)
  rawPayload     Json // original source payload (NEVER tenant-derived data)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  source  OpportunitySource  @relation(fields: [sourceId], references: [id])
  matches OpportunityMatch[] // one-way: the per-tenant join points IN

  @@unique([sourceId, externalId]) // global dedup natural key
  @@index([country, sector])
  @@index([status, closingDate])
  @@index([closingDate])
  @@map("opportunities")
}

/// PER-TENANT — the isolation boundary. One row per (org, opportunity) carrying
/// this org's relevance score + lifecycle. trackingStatus NEW = system-suggested
/// (free); SAVED/CONVERTED = counts against maxTrackedOpportunities.
model OpportunityMatch {
  id                String              @id @default(cuid())
  orgId             String // TENANT BINDING
  opportunityId     String
  savedSearchId     String?
  relevanceScore    Float
  scoreBreakdown    Json? // explainability: which components contributed
  trackingStatus    MatchTrackingStatus @default(NEW)
  convertedTenderId String? // set on convert (this org's tender — same-org enforced in action)
  notes             String?
  dismissedReason   String?
  lastNotifiedAt    DateTime? // alert dedup (Sprint 2 cron uses this)
  createdById       String? // nullable: system-created matches have no member
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  opportunity     Opportunity  @relation(fields: [opportunityId], references: [id], onDelete: Restrict) // catalog churn must NOT delete tenant tracking
  savedSearch     SavedSearch? @relation(fields: [savedSearchId], references: [id], onDelete: SetNull)
  convertedTender Tender?      @relation("TenderFromOpportunity", fields: [convertedTenderId], references: [id], onDelete: SetNull)

  @@unique([orgId, opportunityId]) // idempotent matching
  @@index([orgId, trackingStatus, relevanceScore]) // the feed: filter status, order by score
  @@index([orgId, lastNotifiedAt]) // alert-dedup / "new since" query
  @@index([opportunityId])
  @@map("opportunity_matches")
}

/// PER-TENANT — a standing monitor (the stickiness device). Alert delivery is
/// Sprint 2; the model + quota gate land now.
model SavedSearch {
  id                 String         @id @default(cuid())
  orgId              String
  name               String
  filters            Json           @default("{}") // country, sector, value band, keywords
  useProfileDefaults Boolean        @default(true)
  alertsEnabled      Boolean        @default(false)
  alertFrequency     AlertFrequency @default(DAILY)
  createdById        String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?

  alerts OpportunityAlert[]

  organization Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  matches      OpportunityMatch[]

  @@index([orgId, deletedAt])
  @@index([orgId, alertsEnabled])
  @@map("saved_searches")
}

/// PER-TENANT — append-only digest delivery log (mirrors WebhookDelivery).
/// One row per digest sent to an org; payload holds the matched items shown.
model OpportunityAlert {
  id            String       @id @default(cuid())
  orgId         String // TENANT BINDING
  savedSearchId String? // SetNull: keep the delivery record if the search is deleted
  channel       AlertChannel @default(IN_APP)
  status        AlertStatus  @default(PENDING)
  matchCount    Int
  payload       Json // [{opportunityId, title, score}] snapshot at send time
  sentAt        DateTime?
  readAt        DateTime? // in-app: when the user opened the digest
  error         String?
  createdAt     DateTime     @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  savedSearch  SavedSearch? @relation(fields: [savedSearchId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt])
  @@index([orgId, readAt])
  @@index([status, createdAt])
  @@map("opportunity_alerts")
}

/// PER-TENANT — Bid/No-Bid qualification record (one live analysis per tender;
/// re-running replaces it). The score is DETERMINISTIC factor math; the LLM may
/// only nudge it within a hard ±0.15 band and contributes the qualitative
/// rationale/risks (same fence as the BOQ money engine — AI never sets numbers).
/// The human decision (agree/override) is the training-flywheel signal.
model BidDecision {
  id             String             @id @default(cuid())
  orgId          String // TENANT BINDING
  tenderId       String             @unique // latest analysis per tender
  score          Float // 0..1 final (deterministic base + clamped LLM nudge)
  baseScore      Float // 0..1 deterministic component only (auditability)
  llmAdjustment  Float              @default(0) // clamped to [-0.15, +0.15]
  confidence     Float // 0..1 — how much org history/signal backed this
  recommendation BidRecommendation
  factors        Json // deterministic breakdown: {profileFit, geographyFit, valueFit, historyFit, deadlinePressure, ...}
  rationale      String             @db.Text // LLM qualitative reasoning (EN)
  rationaleAr    String?            @db.Text
  risks          Json? // [{title, severity, detail}]
  questionsToAsk Json? // string[] — what to clarify before committing
  modelVersion   String?
  // Human decision (the record + the flywheel)
  humanDecision  BidRecommendation? // BID | NO_BID (REVIEW is never a human decision)
  decidedById    String?
  decidedAt      DateTime?
  decisionNotes  String?
  createdById    String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tender       Tender       @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([orgId, recommendation])
  @@index([orgId, createdAt])
  @@map("bid_decisions")
}

/// PER-TENANT — append-only proposal review trail. Every gate transition
/// (submit → approve / request changes / reopen) is recorded here; the trail is
/// the approval audit a bid committee can stand behind. Rows are never updated
/// or deleted by application code.
model ProposalReviewEvent {
  id         String               @id @default(cuid())
  orgId      String // TENANT BINDING
  proposalId String
  action     ProposalReviewAction
  note       String? // required for CHANGES_REQUESTED (enforced in the action)
  actorId    String // member who performed the transition
  createdAt  DateTime             @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  proposal     Proposal     @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId, createdAt])
  @@index([orgId, createdAt])
  @@map("proposal_review_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// MARKETPLACE (Sprint 8b) — the partner / JV network.
//
// A DELIBERATE cross-tenant surface, the mirror image of the Discovery catalog:
// there a GLOBAL catalog flows IN with no orgId; here each tenant publishes its
// OWN profile OUT into a shared directory other tenants can browse. Both are
// opt-in exceptions to strict isolation, fenced precisely:
//
//   • A profile is only visible to others when published = true (opt-in).
//   • contactEmail / contactName (the private payload) are revealed to another
//     org ONLY when an ACCEPTED PartnerConnection exists between them. The
//     directory read model in src/lib/data/marketplace.ts must NEVER project
//     those columns for a non-connected viewer — that projection IS the boundary.
//   • Connections are directed requests; either side accepting unlocks contact.
// ─────────────────────────────────────────────────────────────────────────────

/// PER-TENANT, PUBLISHED OUTWARD — one opt-in directory profile per org.
model MarketplaceProfile {
  id            String    @id @default(cuid())
  orgId         String    @unique // one profile per org
  published     Boolean   @default(false) // draft until the org opts in
  displayName   String
  displayNameAr String?
  country       String?   @db.Char(2) // ISO 3166-1
  sectors       String[]  @default([]) // construction | facilities | oil_gas | ...
  capabilities  String[]  @default([]) // free-tag strengths (EPC, MEP, civil, ...)
  employeeBand  String? // banded like Organization.employeeCount
  blurb         String?   @db.Text // the public pitch
  website       String?
  // PRIVATE payload — revealed only to ACCEPTED connections (see read model).
  contactName   String?
  contactEmail  String?
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([published, country]) // directory browse: published, filter by country
  @@index([published, deletedAt])
  @@map("marketplace_profiles")
}

/// CROSS-TENANT JOIN — a directed connection request between two orgs. ACCEPTED
/// is the key that unlocks each side's private contact info to the other. The
/// unique key prevents duplicate requests in the SAME direction; the "are we
/// connected?" check considers BOTH directions (handled in the data layer).
model PartnerConnection {
  id              String           @id @default(cuid())
  requesterOrgId  String
  addresseeOrgId  String
  status          ConnectionStatus @default(PENDING)
  message         String?          @db.Text // intro note from the requester
  responseMessage String?          @db.Text // optional note on accept/decline
  requestedById   String // member who sent the request
  respondedById   String? // member who accepted/declined
  respondedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  requesterOrg Organization @relation("ConnectionRequester", fields: [requesterOrgId], references: [id], onDelete: Cascade)
  addresseeOrg Organization @relation("ConnectionAddressee", fields: [addresseeOrgId], references: [id], onDelete: Cascade)

  @@unique([requesterOrgId, addresseeOrgId]) // one pending/active request per direction
  @@index([addresseeOrgId, status]) // "incoming requests to me"
  @@index([requesterOrgId, status]) // "requests I sent"
  @@map("partner_connections")
}

// ─────────────────────────────────────────────────────────────────────────────
// EMAIL PLATFORM (Resend) — outbound email log + per-member preferences.
//
// EmailLog is BOTH the audit record AND the outbox/queue: high-volume fan-out
// (the daily digest) is written here as QUEUED and drained in rate-limited
// batches (see src/lib/email/email-queue.ts), while low-volume transactional
// mail is sent immediately and logged SENT/FAILED. Every row is org-scoped so
// the workspace-admin "Email activity" viewer is tenant-safe by construction.
// ─────────────────────────────────────────────────────────────────────────────

/// PER-TENANT — one row per outbound email (audit + outbox).
model EmailLog {
  id                String        @id @default(cuid())
  orgId             String // TENANT BINDING
  memberId          String? // recipient member, if they are one (invitees aren't yet)
  toEmail           String // lower-cased recipient address
  category          EmailCategory
  event             String // NotificationEvent value, e.g. "USER_INVITED"
  subject           String
  status            EmailStatus   @default(QUEUED)
  provider          String        @default("resend")
  providerMessageId String? // Resend id — joins delivery webhooks back to this row
  error             String?       @db.Text
  attempts          Int           @default(0)
  payload           Json? // render context snapshot (no secrets) — also feeds batch drain
  sentAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  member       Member?      @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt]) // admin activity view
  @@index([orgId, status]) // admin "failed emails" filter
  @@index([status, createdAt]) // queue drain: oldest QUEUED first
  @@map("email_logs")
}

/// PER-MEMBER — notification opt-outs. One row per member (auto-created with all
/// categories enabled on first read). TRANSACTIONAL mail ignores this.
model NotificationPreference {
  id                    String   @id @default(cuid())
  orgId                 String // TENANT BINDING (denormalized for org-scoped reads)
  memberId              String   @unique
  dailyDigest           Boolean  @default(true)
  proposalNotifications Boolean  @default(true)
  approvalNotifications Boolean  @default(true)
  billingNotifications  Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  member       Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("notification_preferences")
}
