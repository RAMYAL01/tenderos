// ─────────────────────────────────────────────────────────────────────────────
// TenderOS — Prisma Schema
// PostgreSQL · Prisma ORM
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")       // pooled connection (Neon / PgBouncer)
  directUrl = env("DIRECT_URL")         // direct connection for migrations
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum PlanTier {
  STARTER
  PROFESSIONAL
  BUSINESS
  ENTERPRISE
}

enum MemberRole {
  OWNER
  ADMIN
  MANAGER
  SENIOR_WRITER
  WRITER
  REVIEWER
  VIEWER
}

enum TenderStatus {
  DRAFT
  ACTIVE
  SUBMITTED
  WON
  LOST
  NO_DECISION
  CANCELLED
}

enum DocumentStatus {
  PENDING
  QUEUED
  SCANNING
  OCR_PROCESSING
  PARSING
  INDEXING
  READY
  FAILED
  QUARANTINED
}

enum DocumentLanguage {
  ENGLISH
  ARABIC
  BILINGUAL
  UNKNOWN
}

enum RequirementType {
  MANDATORY
  OPTIONAL
  INFORMATIONAL
  CONDITIONAL
}

enum RequirementPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum ComplianceStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  NOT_APPLICABLE
  FLAGGED
}

enum ProposalStatus {
  DRAFT
  IN_REVIEW
  CHANGES_REQUESTED
  APPROVED
  EXPORTED
  ARCHIVED
}

enum SectionType {
  EXECUTIVE_SUMMARY
  COMPANY_OVERVIEW
  TECHNICAL_APPROACH
  METHODOLOGY
  WORK_PLAN
  TEAM_QUALIFICATIONS
  PAST_PERFORMANCE
  EQUIPMENT_RESOURCES
  HEALTH_SAFETY
  LOCAL_CONTENT
  FINANCIAL_PROPOSAL
  CLARIFICATIONS
  APPENDIX
  COVER_LETTER
  CUSTOM
}

enum ExportFormat {
  PDF
  DOCX
  BILINGUAL_PDF
  BILINGUAL_DOCX
}

enum JobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  RETRYING
}

enum AIJobType {
  EXTRACT_REQUIREMENTS
  GENERATE_COMPLIANCE_MATRIX
  DRAFT_SECTION
  EXECUTIVE_SUMMARY
  CLARIFICATION_QUESTIONS
  RECOMMEND_CONTENT
  EMBED_CONTENT
  TRANSLATE_CONTENT
}

enum ContentLanguage {
  EN
  AR
  AR_SA
  AR_AE
  AR_EG
  BILINGUAL
}

enum ContentSource {
  HUMAN
  AI_GENERATED
  AI_REVIEWED
  IMPORTED
}

enum LossReason {
  PRICE
  TECHNICAL_SCORE
  LOCAL_CONTENT
  LATE_SUBMISSION
  INCOMPLETE_SUBMISSION
  DISQUALIFIED
  NO_BID
  OTHER
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 1: Organization
// Multi-tenant root. Every other table has orgId → this.
// clerkOrgId links to Clerk's organization system.
// ─────────────────────────────────────────────────────────────────────────────
model Organization {
  id                String          @id @default(cuid())
  clerkOrgId        String          @unique   // Clerk org ID e.g. "org_xxxx"
  name              String
  nameAr            String?                   // Arabic organization name
  slug              String          @unique
  planTier          PlanTier        @default(STARTER)
  maxSeats          Int             @default(3)
  maxProposalsMonth Int             @default(5)
  aiCreditsMonth    Int             @default(50)
  storageBytesLimit BigInt          @default(2147483648)  // 2 GB
  storageBytesUsed  BigInt          @default(0)
  defaultLanguage   ContentLanguage @default(EN)
  industry          String?         // construction | defense | facilities | oil_gas
  countryCode       String?         @db.Char(2)   // ISO 3166-1: AE, SA, EG, QA
  settings          Json            @default("{}")
  logoUrl           String?
  website           String?
  isActive          Boolean         @default(true)
  trialEndsAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  // Relations
  members              Member[]
  tenders              Tender[]
  contentLibraryItems  ContentLibraryItem[]
  aiJobs               AIJob[]
  subscription         Subscription?
  auditLogs            AuditLog[]

  @@map("organizations")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 2: Member
// A Clerk user within an organization workspace.
// Clerk handles the actual auth; we store workspace-level profile + role.
// ─────────────────────────────────────────────────────────────────────────────
model Member {
  id                String          @id @default(cuid())
  clerkUserId       String                    // Clerk user ID e.g. "user_xxxx"
  orgId             String
  email             String
  name              String
  nameAr            String?
  role              MemberRole      @default(WRITER)
  avatarUrl         String?
  preferredLanguage ContentLanguage @default(EN)
  mfaEnabled        Boolean         @default(false)
  lastLoginAt       DateTime?
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  // Relations
  organization          Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdTenders        Tender[]              @relation("TenderCreatedBy")
  managedTenders        Tender[]              @relation("TenderManager")
  uploadedDocuments     Document[]
  assignedCompliance    ComplianceMatrixRow[] @relation("ComplianceAssignee")
  createdProposals      Proposal[]
  assignedSections      ProposalSection[]     @relation("SectionAssignee")
  editedSections        ProposalSection[]     @relation("SectionEditor")
  createdVersions       ProposalVersion[]
  comments              ProposalComment[]
  libraryItems          ContentLibraryItem[]
  exportJobs            ExportJob[]
  auditLogs             AuditLog[]

  @@unique([orgId, clerkUserId])
  @@unique([orgId, email])
  @@map("members")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 3: Tender
// The top-level container for each bid project.
// Everything (documents, requirements, proposals) belongs to a tender.
// ─────────────────────────────────────────────────────────────────────────────
model Tender {
  id                 String          @id @default(cuid())
  orgId              String
  titleEn            String
  titleAr            String?
  referenceNo        String?         // Client's RFP reference number
  clientName         String?
  clientNameAr       String?
  clientCountry      String?         @db.Char(2)
  sector             String?         // construction | defense | facilities | oil_gas
  tenderType         String?         // RFP | RFQ | ITB | EOI | ITT
  submissionDeadline DateTime?
  estimatedValue     Decimal?        @db.Decimal(18, 2)
  currency           String?         @default("USD") @db.Char(3)
  status             TenderStatus    @default(DRAFT)
  primaryLanguage    ContentLanguage @default(EN)
  tags               String[]        @default([])
  notes              String?
  lossReason         LossReason?
  outcomeNotes       String?         // Post-bid debrief notes
  createdById        String
  assignedManagerId  String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  deletedAt          DateTime?

  // Relations
  organization     Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy        Member                @relation("TenderCreatedBy", fields: [createdById], references: [id])
  assignedManager  Member?               @relation("TenderManager", fields: [assignedManagerId], references: [id])
  documents        Document[]
  requirements     Requirement[]
  proposals        Proposal[]
  complianceRows   ComplianceMatrixRow[]

  @@map("tenders")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 4: Document
// An uploaded RFP/RFQ file. Processing happens async via job queue.
// storageKey → S3 object key.
// ─────────────────────────────────────────────────────────────────────────────
model Document {
  id                  String           @id @default(cuid())
  tenderId            String
  orgId               String
  filename            String
  originalFilename    String
  storageKey          String           @unique  // S3 key
  storageBucket       String
  mimeType            String
  fileSizeBytes       BigInt
  pageCount           Int?
  languageDetected    DocumentLanguage?
  languageConfidence  Float?           // 0.0–1.0
  processingStatus    DocumentStatus   @default(PENDING)
  errorMessage        String?
  retryCount          Int              @default(0)
  ocrCompletedAt      DateTime?
  indexedAt           DateTime?
  checksumSha256      String?          // For dedup detection
  isPrimary           Boolean          @default(false)  // Main RFP document
  uploadedById        String
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  deletedAt           DateTime?

  // Relations
  tender       Tender        @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  uploadedBy   Member        @relation(fields: [uploadedById], references: [id])
  requirements Requirement[]

  @@map("documents")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 5: Requirement
// An individual requirement extracted from a tender document.
// Both AI-extracted and manually added requirements live here.
// ─────────────────────────────────────────────────────────────────────────────
model Requirement {
  id                String              @id @default(cuid())
  tenderId          String
  documentId        String?
  orgId             String
  textEn            String?             // English requirement text
  textAr            String?             // Arabic requirement text
  sectionRef        String?             // Source section e.g. "Section 3.2.1"
  pageRef           Int?                // Source page number
  requirementType   RequirementType     @default(MANDATORY)
  priority          RequirementPriority @default(HIGH)
  confidenceScore   Float?              // AI confidence 0.0–1.0
  isAiExtracted     Boolean             @default(true)
  tags              String[]            @default([])
  createdById       String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?

  // Relations
  tender          Tender               @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  document        Document?            @relation(fields: [documentId], references: [id], onDelete: SetNull)
  complianceRow   ComplianceMatrixRow?

  @@map("requirements")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 6: ComplianceMatrixRow
// One row per requirement per tender.
// Tracks how (and whether) each requirement is addressed.
// ─────────────────────────────────────────────────────────────────────────────
model ComplianceMatrixRow {
  id               String           @id @default(cuid())
  tenderId         String
  requirementId    String           @unique  // One matrix row per requirement
  orgId            String
  responseEn       String?          // How we address this requirement (English)
  responseAr       String?          // How we address this requirement (Arabic)
  sectionReference String?          // Which proposal section addresses this
  status           ComplianceStatus @default(NOT_STARTED)
  assignedToId     String?
  dueDate          DateTime?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  tender      Tender      @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  requirement Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  assignedTo  Member?     @relation("ComplianceAssignee", fields: [assignedToId], references: [id])

  @@map("compliance_matrix_rows")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 7: Proposal
// A draft technical proposal for a tender.
// Multiple proposals can exist per tender (e.g., EN + AR versions).
// ─────────────────────────────────────────────────────────────────────────────
model Proposal {
  id              String          @id @default(cuid())
  tenderId        String
  orgId           String
  title           String
  language        ContentLanguage @default(EN)
  status          ProposalStatus  @default(DRAFT)
  currentVersion  Int             @default(1)
  complianceScore Float?          // Cached %, recalculated on compliance update
  submittedAt     DateTime?
  createdById     String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  // Relations
  tender     Tender            @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  createdBy  Member            @relation(fields: [createdById], references: [id])
  sections   ProposalSection[]
  versions   ProposalVersion[]
  comments   ProposalComment[]
  exportJobs ExportJob[]

  @@map("proposals")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 8: ProposalSection
// A single section within a proposal (e.g., Technical Approach, Methodology).
// Supports both AI-generated and human-authored content, bilingual.
// ─────────────────────────────────────────────────────────────────────────────
model ProposalSection {
  id             String        @id @default(cuid())
  proposalId     String
  orgId          String
  sectionType    SectionType   @default(CUSTOM)
  titleEn        String?
  titleAr        String?
  contentEn      String?       @db.Text  // Rich text / Markdown
  contentAr      String?       @db.Text
  orderIndex     Int           @default(0)
  isAiGenerated  Boolean       @default(false)
  aiModelUsed    String?       // e.g. "claude-3-5-sonnet-20241022"
  contentSource  ContentSource @default(HUMAN)
  assignedToId   String?
  lastEditedById String?
  isLocked       Boolean       @default(false)  // Prevent concurrent edits
  lockedById     String?       // Member ID (no relation — simple lock ref)
  lockedAt       DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  // Relations
  proposal     Proposal         @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  assignedTo   Member?          @relation("SectionAssignee", fields: [assignedToId], references: [id])
  lastEditedBy Member?          @relation("SectionEditor", fields: [lastEditedById], references: [id])
  comments     ProposalComment[]

  @@map("proposal_sections")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 9: ProposalVersion
// Immutable snapshots of a proposal at a point in time.
// snapshot JSON contains the full sections content for that version.
// ─────────────────────────────────────────────────────────────────────────────
model ProposalVersion {
  id              String   @id @default(cuid())
  proposalId      String
  orgId           String
  versionNumber   Int
  label           String?  // e.g. "v3 - Final Review"
  snapshot        Json     // Full ProposalSection[] snapshot
  changeSummary   String?
  complianceScore Float?
  createdById     String
  createdAt       DateTime @default(now())

  // Relations
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  createdBy  Member   @relation(fields: [createdById], references: [id])

  @@unique([proposalId, versionNumber])
  @@map("proposal_versions")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 10: ContentLibraryItem
// Reusable content blocks — past performance, CVs, methodology templates.
// Supports semantic search via embedding (stored externally or future pgvector).
// ─────────────────────────────────────────────────────────────────────────────
model ContentLibraryItem {
  id            String          @id @default(cuid())
  orgId         String
  titleEn       String
  titleAr       String?
  contentEn     String?         @db.Text
  contentAr     String?         @db.Text
  sectionType   SectionType?
  tags          String[]        @default([])
  language      ContentLanguage @default(EN)
  isTemplate    Boolean         @default(false)  // Workspace-wide template
  usageCount    Int             @default(0)
  contentSource ContentSource   @default(HUMAN)
  // Embedding stored as JSON array until pgvector is configured
  embeddingEn   Json?           // Float[] from OpenAI text-embedding-3-large
  embeddingAr   Json?
  createdById   String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  // Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy    Member       @relation(fields: [createdById], references: [id])

  @@map("content_library_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 11: ProposalComment
// Inline comments on proposals and sections. Supports threaded replies.
// ─────────────────────────────────────────────────────────────────────────────
model ProposalComment {
  id          String    @id @default(cuid())
  proposalId  String
  sectionId   String?
  orgId       String
  parentId    String?   // For threaded replies
  text        String
  mentions    String[]  @default([])  // Member IDs mentioned with @
  isResolved  Boolean   @default(false)
  resolvedById String?  // Member ID (no relation — simple ref)
  resolvedAt  DateTime?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relations
  proposal  Proposal         @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  section   ProposalSection? @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  parent    ProposalComment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies   ProposalComment[] @relation("CommentThread")
  createdBy Member            @relation(fields: [createdById], references: [id])

  @@map("proposal_comments")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 12: ExportJob
// Tracks async export operations (PDF/DOCX generation).
// outputStorageKey → S3 key of generated file.
// ─────────────────────────────────────────────────────────────────────────────
model ExportJob {
  id                String          @id @default(cuid())
  proposalId        String
  orgId             String
  format            ExportFormat
  language          ContentLanguage
  status            JobStatus       @default(QUEUED)
  outputStorageKey  String?         // S3 key
  outputFilename    String?
  outputSizeBytes   BigInt?
  downloadExpiresAt DateTime?       // Pre-signed URL expiry
  errorMessage      String?
  processingMs      Int?
  createdById       String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  proposal  Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  createdBy Member   @relation(fields: [createdById], references: [id])

  @@map("export_jobs")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 13: AIJob
// Tracks all AI operations for cost accounting and quota management.
// Covers extraction, drafting, translation, embedding, etc.
// ─────────────────────────────────────────────────────────────────────────────
model AIJob {
  id               String    @id @default(cuid())
  orgId            String
  memberId         String?
  jobType          AIJobType
  resourceType     String?   // tender | document | proposal | section
  resourceId       String?   // ID of the resource being processed
  modelName        String?   // e.g. "claude-3-5-sonnet-20241022"
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  costUsd          Decimal?  @db.Decimal(10, 6)
  latencyMs        Int?
  status           JobStatus @default(QUEUED)
  progress         Int       @default(0)  // 0–100
  resultRef        String?   // S3 key or inline JSON for small results
  errorMessage     String?
  retryCount       Int       @default(0)
  maxRetries       Int       @default(3)
  inputMetadata    Json      @default("{}")
  outputMetadata   Json      @default("{}")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("ai_jobs")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 14: Subscription
// One subscription per organization. Tracks Stripe billing state.
// ─────────────────────────────────────────────────────────────────────────────
model Subscription {
  id                   String    @id @default(cuid())
  orgId                String    @unique
  planTier             PlanTier
  seats                Int       @default(3)
  billingCycle         String    @default("monthly")  // monthly | annual
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean   @default(false)
  stripeCustomerId     String?
  stripeSubId          String?   @unique
  stripePriceId        String?
  proposalsUsed        Int       @default(0)
  aiCreditsUsed        Int       @default(0)
  storageBytesUsed     BigInt    @default(0)
  isTrial              Boolean   @default(false)
  trialEndsAt          DateTime?
  // status: trialing | active | past_due | cancelled | unpaid
  status               String    @default("active")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODEL 15: AuditLog
// Immutable audit trail. Records every significant action.
// Application code INSERTS only — never updates or deletes rows here.
// ─────────────────────────────────────────────────────────────────────────────
model AuditLog {
  id           String   @id @default(cuid())
  orgId        String?
  memberId     String?
  action       String   // e.g. "document.upload" | "proposal.export" | "member.role_changed"
  resourceType String?  // tender | document | proposal | member
  resourceId   String?
  oldValues    Json?    // Before state (for updates)
  newValues    Json?    // After state
  metadata     Json     @default("{}")   // IP, user agent, session
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  // Relations
  organization Organization? @relation(fields: [orgId], references: [id])
  member       Member?       @relation(fields: [memberId], references: [id])

  @@map("audit_logs")
}
