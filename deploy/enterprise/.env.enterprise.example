# TenderOS Enterprise (.env) — copy to .env, fill secrets, keep OUT of git.
# Every value below resolves to an in-network service; there is NO external API.

# ── Postgres + pgvector ──────────────────────────────────────────────
PG_USER=tenderos
PG_PASSWORD=                      # strong; rotate via secrets manager / Vault
PG_DB=tenderos

# ── Private LLM (vLLM serving Qwen2.5 from a local weights volume) ────
LLM_MODEL_PATH=/models/Qwen2.5-14B-Instruct
TP_SIZE=1                         # tensor-parallel = number of GPUs for the model

# ── Local embeddings (MUST output 1536 dims to match the pgvector column) ──
OLLAMA_EMBED_MODEL=bge-m3         # strong Arabic+English; pin to 1536 dims

# ── Enterprise SSO (Keycloak; Azure AD federates in via OIDC/SAML) ───
KC_ADMIN=admin
KC_ADMIN_PASSWORD=
OIDC_ISSUER=https://sso.gov.local/realms/tenderos
OIDC_CLIENT_ID=tenderos
OIDC_CLIENT_SECRET=

# ── On-prem object storage (MinIO, S3-compatible) ───────────────────
MINIO_USER=
MINIO_PASSWORD=
S3_BUCKET=tenderos

# ── App ─────────────────────────────────────────────────────────────
APP_IMAGE=registry.internal/tenderos:enterprise
APP_URL=https://tenderos.gov.local
TRAINING_HMAC_KEY=                # for on-prem dataset de-identification
INTERNAL_API_KEY=
CRON_SECRET=
