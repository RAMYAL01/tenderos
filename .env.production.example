# ─────────────────────────────────────────────────────────────────
# TenderOS — Production Environment Variables
# Set these in Vercel Project Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# Use connection pooling (PgBouncer) for production:
# Neon: postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neon?sslmode=require&pgbouncer=true
# Supabase: postgresql://postgres.[ref]:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://user:password@host:5432/tenderos?sslmode=require"

# ── Clerk ─────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_xxxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_live_xxxxxxxxxxxxx"
CLERK_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxx"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# ── AWS S3 ────────────────────────────────────────────────────────
# Use a dedicated IAM role with least-privilege S3 permissions
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."
AWS_REGION="me-central-1"
AWS_S3_BUCKET_NAME="tenderos-production"
AWS_CLOUDFRONT_URL="https://d1234567890.cloudfront.net"

# ── AI Providers ──────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-api03-..."
OPENAI_API_KEY="sk-proj-..."

# ── Internal ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY="..."

# ── Monitoring ────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
SENTRY_ORG="tenderos"
SENTRY_PROJECT="tenderos-nextjs"
SENTRY_AUTH_TOKEN="sntrys_xxx"

# ── App ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://app.tenderos.ai"
NEXT_PUBLIC_APP_NAME="TenderOS"
NODE_ENV="production"

# ── Rate Limiting (Optional — Upstash Redis) ──────────────────────
# Sign up at upstash.com for a free Redis database
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="xxx"

# ── Optional: Stripe Billing ──────────────────────────────────────
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
